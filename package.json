{
    "name": "flager-backend",
    "version": "1.0.0",
    "description": "Flager Social Media Backend API",
    "main": "dist/server.js",
    "scripts": {
        "dev": "nodemon",
        "build": "tsc",
        "start": "node dist/server.js",
        "lint": "eslint . --ext .ts",
        "lint:fix": "eslint . --ext .ts --fix",
        "seed": "ts-node -r tsconfig-paths/register src/seed-data.ts",
        "backup:products": "ts-node -r tsconfig-paths/register src/scripts/backup-products-collection.ts",
        "embed:products": "ts-node -r tsconfig-paths/register src/scripts/embed-products.ts",
        "test": "playwright test",
        "test:ui": "playwright test --ui",
        "test:debug": "playwright test --debug",
        "test:report": "playwright show-report"
    },
    "dependencies": {
        "@google/generative-ai": "^0.24.1",
        "@payos/node": "^2.0.5",
        "@supabase/supabase-js": "^2.93.1",
        "@types/bcrypt": "^6.0.0",
        "axios": "^1.11.0",
        "bcrypt": "^6.0.0",
        "bcryptjs": "^2.4.3",
        "bullmq": "^5.66.7",
        "cloudinary": "^1.41.3",
        "compression": "^1.7.4",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^5.1.0",
        "express-rate-limit": "^7.1.5",
        "express-session": "^1.19.0",
        "helmet": "^7.1.0",
        "ioredis": "^5.9.2",
        "jsonwebtoken": "^9.0.2",
        "mime": "^4.1.0",
        "moment": "^2.30.1",
        "moment-timezone": "^0.6.0",
        "mongoose": "^8.0.3",
        "morgan": "^1.10.0",
        "multer": "^2.0.1",
        "multer-storage-cloudinary": "^4.0.0",
        "neo4j-driver": "^5.14.0",
        "nodemailer": "^7.0.13",
        "passport": "^0.7.0",
        "passport-google-oauth20": "^2.0.0",
        "redis": "^4.6.11",
        "socket.io": "^4.6.1",
        "zod": "^4.2.1"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@types/bcryptjs": "^2.4.6",
        "@types/compression": "^1.7.5",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.3",
        "@types/express-session": "^1.18.2",
        "@types/ioredis": "^4.28.10",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/moment-timezone": "^0.5.13",
        "@types/morgan": "^1.9.9",
        "@types/multer": "^1.4.11",
        "@types/node": "^24.12.0",
        "@types/nodemailer": "^7.0.9",
        "@types/passport": "^1.0.17",
        "@types/passport-google-oauth20": "^2.0.17",
        "@types/ws": "^8.18.1",
        "@typescript-eslint/eslint-plugin": "^6.14.0",
        "@typescript-eslint/parser": "^6.14.0",
        "eslint": "^8.55.0",
        "nodemon": "^3.0.2",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.8.3"
    }
}
