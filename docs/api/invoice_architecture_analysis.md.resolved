## 💡 Giải Pháp Đề Xuất

### Giải Pháp 1: Tạo Schema Mới Cho Client Request

**Tạo file mới**: `src/types/invoice/client-invoice.ts`

```typescript
import z from 'zod';
import { OrderProductSchema } from '../order/order-product';
import { AddressSchema } from '../customer/address';
import { PaymentMethodType } from '../../config/enums/payment.enum';

export const ClientCreateInvoiceSchema = z.object({
    // ✅ Nhận products thay vì orders
    products: z.array(OrderProductSchema).min(1, 'At least one product is required'),
    
    // ✅ Bắt buộc có paymentMethod
    paymentMethod: z.nativeEnum(PaymentMethodType),
    
    // ✅ Thông tin giao hàng
    address: AddressSchema,
    fullName: z.string().min(1, 'Full name is required'),
    phone: z.string().min(1, 'Phone number is required'),
    
    // ✅ Voucher (optional)
    voucher: z.array(z.string()).optional(),
    
    // ✅ Ghi chú (optional)
    note: z.string().optional(),
    
    // ❌ KHÔNG CHO CLIENT GỬI totalPrice và totalDiscount
});

export type ClientCreateInvoice = z.infer<typeof ClientCreateInvoiceSchema>;
```

**Cập nhật route** ([invoice.route.ts:15-19](file:///d:/code/SW391/be-swp391-eye-wear/src/routes/client/invoice.route.ts#L15-L19)):
```typescript
import { ClientCreateInvoiceSchema } from '../../types/invoice/client-invoice';

router.post(
    '/',
    validateBody(ClientCreateInvoiceSchema),  // ← Dùng schema mới
    invoiceController.createInvoice
);
```

### Giải Pháp 2: Server-Side Price Calculation với Validation

**Cập nhật Service** ([invoice.service.ts:101-421](file:///d:/code/SW391/be-swp391-eye-wear/src/services/client/invoice.service.ts#L101-L421)):

```typescript
createInvoice = async (customerId: string, payload: ClientCreateInvoice) => {
    let calculatedTotalPrice = 0;
    
    // 1. Tính giá từ database
    for (const item of payload.products) {
        const product = await productRepository.findOne({...});
        const variant = product.variants.find(v => v.sku === item.sku);
        
        calculatedTotalPrice += variant.finalPrice * item.quantity;
    }
    
    // 2. Áp dụng voucher
    const discount = await this.calculateVoucherDiscount(
        payload.voucher,
        calculatedTotalPrice,
        customerId
    );
    
    // 3. Tạo invoice với giá đã tính
    const invoice = await invoiceRepository.create({
        // ...
        totalPrice: calculatedTotalPrice,      // ← Server tính
        totalDiscount: discount,                // ← Server tính
        // ...
    });
    
    return {
        invoice,
        finalPrice: calculatedTotalPrice - discount
    };
};
```

### Giải Pháp 3: Sửa Logic Nhóm Order

**Refactor Service**:

```typescript
createInvoice = async (customerId: string, payload: ClientCreateInvoice) => {
    const normalProducts: OrderProduct[] = [];
    const manufacturingProducts: OrderProduct[] = [];
    
    // 1. Phân loại sản phẩm
    for (const item of payload.products) {
        if (item.lens) {
            manufacturingProducts.push(item);
        } else {
            normalProducts.push(item);
        }
    }
    
    const createdOrders: string[] = [];
    
    // 2. Tạo 1 Order NORMAL cho tất cả sản phẩm thường
    if (normalProducts.length > 0) {
        const normalOrder = await orderRepository.create({
            type: OrderType.NORMAL,
            products: normalProducts,  // ← Gom tất cả
            // ...
        });
        createdOrders.push(normalOrder._id.toString());
    }
    
    // 3. Tạo Order MANUFACTURING riêng cho từng sản phẩm có lens
    for (const item of manufacturingProducts) {
        const mfgOrder = await orderRepository.create({
            type: OrderType.MANUFACTURING,
            products: [item],  // ← Mỗi lens = 1 order
            // ...
        });
        createdOrders.push(mfgOrder._id.toString());
    }
    
    // 4. Tạo Invoice
    const invoice = await invoiceRepository.create({
        orders: createdOrders,
        // ...
    });
};
```

### Giải Pháp 4: Thêm Validation Layer

**Tạo middleware mới**: `src/middlewares/invoice-validation.middleware.ts`

```typescript
export const validateInvoiceIntegrity = async (
    req: Request,
    res: Response,
    next: NextFunction
) => {
    const { products, voucher } = req.body;
    
    // 1. Validate products tồn tại và có stock
    for (const item of products) {
        const product = await productRepository.findOne({
            _id: item.product?.product_id || item.lens?.lens_id
        });
        
        if (!product) {
            throw new NotFoundRequestError('Product not found');
        }
        
        const variant = product.variants.find(v => v.sku === item.sku);
        if (!variant || variant.stock < item.quantity) {
            throw new ConflictRequestError('Insufficient stock');
        }
    }
    
    // 2. Validate voucher (nếu có)
    if (voucher && voucher.length > 0) {
        const voucherDoc = await voucherRepository.findOne({
            code: voucher[0].toUpperCase()
        });
        
        if (!voucherDoc || voucherDoc.status !== 'ACTIVE') {
            throw new BadRequestError('Invalid voucher');
        }
    }
    
    next();
};
```

**Áp dụng vào route**:
```typescript
router.post(
    '/',
    validateBody(ClientCreateInvoiceSchema),
    validateInvoiceIntegrity,  // ← Thêm middleware
    invoiceController.createInvoice
);
```

